rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 업로드 이력서 파일: 본인만 읽기/쓰기
    match /resumeFiles/{userId}/{fileId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.size < 20 * 1024 * 1024 &&
                       request.resource.contentType.matches('(application/pdf|image/jpeg|image/jpg|image/png)');
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }

    // 이력서 프로필 사진: 본인만 쓰기, 로그인 사용자 읽기 (병원 열람용)
    match /resumes/{userId}/photos/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.size < 3 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/(jpeg|jpg|png)');
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }

    // 구인공고 이미지: 승인된 공고자만 쓰기, 로그인 사용자 읽기
    match /jobs/{jobId}/images/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.size < 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // 사업자 인증 첨부(이미지·PDF): 로그인한 사용자만 (경로는 코드와 동일하게 clinicVerifications)
    match /clinicVerifications/{allPaths=**} {
      allow read:  if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.size < 10 * 1024 * 1024 &&
                       request.resource.contentType.matches(
                         '(image/jpeg|image/jpg|image/png|application/pdf)'
                       );
      allow update: if request.auth != null &&
                       request.resource.size < 10 * 1024 * 1024 &&
                       request.resource.contentType.matches(
                         '(image/jpeg|image/jpg|image/png|application/pdf)'
                       );
      allow delete: if request.auth != null;
    }

    // 기록하기 사진: 본인 경로만 읽기/쓰기/삭제
    match /diary_posts/{userId}/{postId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.size < 2 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/(jpeg|jpg|png)');
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }

    // 이력서 OCR 원본 이미지: 본인만 쓰기/읽기/삭제
    match /resumeImports/{userId}/{draftId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.size < 10 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }

    // 나머지: 로그인한 사용자 읽기만 허용, 쓰기는 금지
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
