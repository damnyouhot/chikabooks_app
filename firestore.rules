rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ══════════════════════════════════════════════════
    // 유저
    // ══════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // 본인 문서 전체 쓰기 — careerProfile, lastImportedResumeId, lastImportedResumeAt 등
      allow write: if request.auth != null && request.auth.uid == uid;

      // ── 📝 나만 보는 한 줄 기록 (notes) ──
      match /notes/{noteId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── 차단한 사용자 목록 (blockedUsers) ──
      match /blockedUsers/{blockedUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // 공감·퀴즈 보상 먹이 중복 방지 (클라이언트 트랜잭션)
      match /caringTreatGrants/{grantId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ══════════════════════════════════════════════════
    // 공고자(치과) 마스터 계정
    // ══════════════════════════════════════════════════
    match /clinics_accounts/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // 생성: 본인만 + 서버 전용 필드 초기값 고정
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.approvalStatus == 'pending'
        && request.resource.data.canPost == false;

      // 수정: 본인만 + 서버 전용 필드(승인·인증) 변경 불가
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.approvalStatus == resource.data.approvalStatus
        && request.resource.data.canPost == resource.data.canPost
        && request.resource.data.clinicVerified == resource.data.clinicVerified
        && request.resource.data.get('identityVerified', false) == resource.data.get('identityVerified', false);

      allow delete: if false;

      // ── 치과 프로필 (다중 지점 지원) ──
      match /clinic_profiles/{profileId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        // 사업자 인증 상태는 서버만 변경 가능
        allow update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.get('businessVerification', {}).get('status', 'none')
             == resource.data.get('businessVerification', {}).get('status', 'none');
        allow delete: if false;
      }
    }

    // ══════════════════════════════════════════════════
    // 🎫 공고권 (Vouchers)
    // ══════════════════════════════════════════════════
    match /vouchers/{voucherId} {
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      // 생성·수정·삭제: 서버만 (발급/사용/만료 처리)
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 🧾 주문 (Orders)
    // ══════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      // 생성·수정·삭제: 서버만 (결제 검증 후 상태 전환)
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 공개 프로필 (닉네임 등 최소 필드만)
    // ══════════════════════════════════════════════════
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════
    // 주간 목표 (Weekly Goals)
    // ══════════════════════════════════════════════════
    match /weeklyGoals/{docId} {
      // docId 형식: {uid}_{weekKey} (예: abc123_2026-W07)
      allow read, write: if request.auth != null && 
        docId.matches('^' + request.auth.uid + '_.*');
    }

    // ══════════════════════════════════════════════════
    // 🔐 API 키 (클라이언트 접근 금지 — Admin SDK/콘솔만)
    // Cloud Functions는 보안 규칙을 우회하므로 sync 등 서버 코드는 그대로 동작함.
    // ══════════════════════════════════════════════════
    match /api_keys/{keyDoc} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════
    // ⚙️ 설정 (로그인한 모든 사용자 읽기 가능)
    // ══════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if request.auth != null; // 로그인한 모든 사용자
      allow write: if false; // 콘솔에서만 수정
    }

    // ══════════════════════════════════════════════════
    // 📋 HIRA 업데이트 (급여/수가 변경)
    // ══════════════════════════════════════════════════
    match /content_hira_updates/{updateId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions만
      
      // ── 댓글 서브컬렉션 ──
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500;
        allow delete: if request.auth != null && 
          resource.data.uid == request.auth.uid;
        allow update: if false; // 댓글 수정 불가
      }
    }

    match /content_hira_digest/{dateKey} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions만
    }

    // ══════════════════════════════════════════════════
    // 💾 HIRA 저장 목록 (사용자별)
    // ══════════════════════════════════════════════════
    match /users/{uid}/saved_hira_updates/{updateId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow update: if false; // 생성/삭제만, 수정 불필요
    }

    // ══════════════════════════════════════════════════
    // 구인공고 (Jobs)
    // ══════════════════════════════════════════════════
    match /jobs/{jobId} {
      // 공고 읽기: 로그인한 모든 사용자 (published 상태)
      allow read: if request.auth != null;
      // 생성/수정/삭제: 서버(Cloud Functions)만 (createJobPosting Callable)
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 치과 사업자 인증 (Clinic Verifications)
    // ══════════════════════════════════════════════════
    match /clinicVerifications/{uid} {
      // 본인 기록만 읽기
      allow read: if request.auth != null && request.auth.uid == uid;
      // 최초 제출(pending): 본인만
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.status == 'pending';
      // 승인/거절 등 상태 변경: 서버만
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 🏥 치과(병원) (Clinics)
    // ══════════════════════════════════════════════════
    match /clinics/{clinicId} {
      // 읽기: 소유자/멤버 또는 지원자(공고 열람 시 병원 정보 참조)
      allow read: if request.auth != null;
      // 쓰기: 서버(Cloud Functions)만 – 인증 승인 시 자동 생성
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    // 📄 이력서 (Resumes)
    // ══════════════════════════════════════════════════
    match /resumes/{resumeId} {
      // 읽기: 본인만 (병원은 application 경유로 서버에서 조회)
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      // 생성: 본인 uid만
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      // 수정: 본인만
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      // 삭제: 본인만
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📁 업로드 원본 이력서 파일 (Resume Files)
    // ══════════════════════════════════════════════════
    match /resumeFiles/{fileId} {
      // 읽기: 본인만
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      // 생성: 본인 uid로만
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.fileType in ['pdf', 'jpg', 'jpeg', 'png'];
      // 수정: 본인만 (displayName, isPrimary, status만 변경 가능)
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      // 삭제: 본인만
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 🖼️ 이력서 OCR 가져오기 드래프트 (Resume Import Drafts)
    // ══════════════════════════════════════════════════
    match /resumeImportDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📝 이력서 편집 임시저장 (Resume Drafts)
    // ══════════════════════════════════════════════════
    match /resumeDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📨 지원서 (Applications)
    // ══════════════════════════════════════════════════
    match /applications/{applicationId} {
      // 읽기: 지원자 본인 또는 해당 병원 소유자
      allow read: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/clinics/$(resource.data.clinicId)).data.ownerUids
      );
      // 생성: 지원자 본인 uid로만
      allow create: if request.auth != null &&
        request.resource.data.applicantUid == request.auth.uid;
      // 수정: 서버만 (연락처 공개 등)
      allow update: if false;
      // 삭제: 지원자가 철회(withdraw) – 서버 Function 경유 권장
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 📝 공고 임시저장 (Job Drafts)
    // ══════════════════════════════════════════════════
    match /jobDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📊 공고 일별 통계 (Job Stats Daily)
    // ══════════════════════════════════════════════════
    match /jobStatsDaily/{docId} {
      // 읽기: 해당 공고의 병원 소유자만 (또는 로그인 유저 – MVP)
      allow read: if request.auth != null;
      // 쓰기: 서버만 (Cloud Functions에서 집계)
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    // 🔗 커리어 네트워크 (Career Network)
    // ══════════════════════════════════════════════════
    match /careerNetwork/{docId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow write: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📋 피드백 게시판 (Feedbacks)
    // ══════════════════════════════════════════════════
    function isAdminUser() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /feedbacks/{feedbackId} {
      // 읽기: public 글은 로그인한 모든 유저, private는 관리자 또는 작성자만
      allow read: if request.auth != null && (
        resource.data.visibility == 'public' ||
        isAdminUser() ||
        resource.data.uid == request.auth.uid
      );

      // 생성: 로그인한 본인 uid로만
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 1000 &&
        request.resource.data.visibility in ['public', 'private'] &&
        request.resource.data.type in ['improvement', 'positive'] &&
        request.resource.data.priority in ['high', 'medium', 'low'];

      // 수정: 작성자(text/type/priority/visibility 변경) 또는 관리자(adminStatus 포함 전체)
      allow update: if request.auth != null && (
        isAdminUser() ||
        (
          resource.data.uid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['text', 'type', 'priority', 'visibility', 'updatedAt'])
        )
      );

      // 삭제: 작성자 또는 관리자
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid || isAdminUser()
      );

      // ── 댓글 서브컬렉션 ──
      match /comments/{commentId} {
        // 읽기: 부모 피드백 읽기 권한과 동일
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/feedbacks/$(feedbackId)).data.visibility == 'public' ||
          isAdminUser() ||
          get(/databases/$(database)/documents/feedbacks/$(feedbackId)).data.uid == request.auth.uid
        );

        // 생성: 로그인한 본인 uid로만, 텍스트 최대 500자
        allow create: if request.auth != null &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500;

        // 수정: 불가
        allow update: if false;

        // 삭제: 댓글 작성자 또는 관리자
        allow delete: if request.auth != null && (
          resource.data.uid == request.auth.uid || isAdminUser()
        );
      }
    }

    // ══════════════════════════════════════════════════
    // 🗳️ 공감투표 (Empathy Polls)
    // ══════════════════════════════════════════════════
    match /polls/{pollId} {
      // 읽기: 로그인한 모든 유저
      allow read: if request.auth != null;
      // 쓰기: 서버(Cloud Functions / 관리 콘솔)만
      allow create, update, delete: if false;

      // ── 보기(선택지) ──
      match /options/{optionId} {
        allow read: if request.auth != null;

        // 사용자 보기 추가: 로그인 유저만, isSystem=false 강제
        allow create: if request.auth != null
          && request.resource.data.isSystem == false
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 50
          && request.resource.data.authorNickname is string
          && request.resource.data.authorNickname.size() <= 30
          && request.resource.data.empathyCount == 0
          && request.resource.data.reportCount == 0
          && request.resource.data.isHidden == false;

        // empathyCount/reportCount/isHidden 변경은 트랜잭션에서 처리
        // 클라이언트 트랜잭션도 통과하도록 허용
        allow update: if request.auth != null;

        // 사용자 추가 보기: 작성자만 삭제 — 공감 0 또는 공감 1(본인 표만)
        allow delete: if request.auth != null
          && resource.data.isSystem == false
          && resource.data.authorUid == request.auth.uid
          && (
            resource.data.empathyCount == 0
            || (
              resource.data.empathyCount == 1
              && exists(/databases/$(database)/documents/polls/$(pollId)/votes/$(request.auth.uid))
              && get(/databases/$(database)/documents/polls/$(pollId)/votes/$(request.auth.uid)).data.optionId == optionId
            )
          );

        // ── 신고 서브컬렉션 ──
        match /reports/{reportId} {
          // 보기 작성자가 삭제 전 신고 문서 정리용으로 조회
          allow read: if request.auth != null
            && get(/databases/$(database)/documents/polls/$(pollId)/options/$(optionId)).data.authorUid == request.auth.uid;
          allow create: if request.auth != null
            && request.auth.uid == reportId
            && request.resource.data.reason is string
            && request.resource.data.reason.size() >= 1
            && request.resource.data.reason.size() <= 80;
          allow update: if false;
          allow delete: if request.auth != null
            && get(/databases/$(database)/documents/polls/$(pollId)/options/$(optionId)).data.authorUid == request.auth.uid;
        }
      }

      // ── 투표(votes) ──
      match /votes/{voteUid} {
        // 읽기: 본인만
        allow read: if request.auth != null && request.auth.uid == voteUid;
        // 생성/수정: 본인만 (트랜잭션에서 사용)
        allow create, update: if request.auth != null
          && request.auth.uid == voteUid;
        // 본인 문서만 삭제 (작성자 보기 삭제 시 공감 정리용, CF에서도 Admin으로 삭제)
        allow delete: if request.auth != null && request.auth.uid == voteUid;
      }

      // ── 종료 투표 한마디 댓글 ──
      match /pollComments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && (
            get(/databases/$(database)/documents/polls/$(pollId)).data.status == 'closed'
            || get(/databases/$(database)/documents/polls/$(pollId)).data.endsAt < request.time
          )
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;
        allow update, delete: if false;
      }
    }

    // ══════════════════════════════════════════════════
    // 📊 행동 분석 일별 집계 (Analytics Daily)
    // ══════════════════════════════════════════════════
    match /analytics_daily/{dateKey} {
      allow read: if request.auth != null && isAdminUser();
      allow write: if false; // Cloud Functions만
    }

    // ══════════════════════════════════════════════════
    // 📦 퀴즈 패크 메타 (임상 세트 전환용, 읽기만)
    // ══════════════════════════════════════════════════
    match /quiz_packs/{packId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    // 🔔 알림 (Notifications)
    // ══════════════════════════════════════════════════
    match /notifications/{uid} {
      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // 클라이언트는 read 플래그만 변경 가능
        allow update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        // 생성·삭제: 서버만
        allow create, delete: if false;
      }
    }

    // ══════════════════════════════════════════════════
    // 기타 컬렉션 (임시로 전체 허용 - 나중에 세분화 필요)
    // ══════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if true;
    }
  }
}