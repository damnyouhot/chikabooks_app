rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ══════════════════════════════════════════════════
    // 파트너 그룹
    // ══════════════════════════════════════════════════
    match /partnerGroups/{groupId} {
      // 그룹 멤버만 읽기 가능
      allow read: if request.auth != null && 
                     request.auth.uid in resource.data.memberUids;
      // 쓰기는 서버만 (Cloud Functions)
      allow write: if false;

      // ── 슬롯 (서버만 쓰기) ──
      match /slots/{slotId} {
        allow read: if request.auth != null && 
                       request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
        allow write: if false; // 서버만
      }

      // ── 이벤트 로그 (서버 내부용) ──
      match /events/{eventId} {
        allow read: if false; // 클라이언트 읽기 금지
        allow write: if false; // 서버만
      }

      // ── 멤버 메타 ──
      match /memberMeta/{uid} {
        allow read: if request.auth != null && 
                       request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
        allow write: if false;
      }

      // ── 활동 로그 (기존) ──
      match /activityLogs/{logId} {
        allow read: if request.auth != null && 
                       request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
        allow write: if false;
      }

      // ── 게시물 (bondGroups 내부) ──
      match /posts/{postId} {
        allow read: if request.auth != null && 
                       request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
        allow write: if request.auth != null && 
                        request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;

        // ── 추대 서브컬렉션 ──
        match /enthrones/{enthUID} {
          allow read: if request.auth != null && 
                         request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
          allow create: if request.auth != null && 
                           request.auth.uid == enthUID &&
                           request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
          allow delete: if request.auth != null && request.auth.uid == enthUID;
        }
      }

      // ── 일일 요약 ──
      match /dailySummaries/{dateKey} {
        allow read: if request.auth != null && 
                       request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
        allow write: if false; // 서버만 (Cloud Functions)
      }
    }

    // ══════════════════════════════════════════════════
    // 유저
    // ══════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      // ── 파트너 인박스 (서버만 쓰기) ──
      match /partnerInbox/{inboxId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // 서버만
      }

      // ── 📝 나만 보는 한 줄 기록 (notes) ──
      match /notes/{noteId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── 차단한 사용자 목록 (blockedUsers) ──
      match /blockedUsers/{blockedUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ══════════════════════════════════════════════════
    // 공개 프로필 (닉네임 등 최소 필드만)
    // ══════════════════════════════════════════════════
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════
    // 주간 목표 (Weekly Goals)
    // ══════════════════════════════════════════════════
    match /weeklyGoals/{docId} {
      // docId 형식: {uid}_{weekKey} (예: abc123_2026-W07)
      allow read, write: if request.auth != null && 
        docId.matches('^' + request.auth.uid + '_.*');
    }

    // ══════════════════════════════════════════════════
    // 결을 같이하기 게시물 (Bond Posts)
    // ══════════════════════════════════════════════════
    match /bondPosts/{postId} {
      // 읽기: 로그인한 모든 유저 (단, 숨김 처리된 글 제외)
      allow read: if request.auth != null;
      
      // 쓰기: 로그인한 유저, 자신의 uid로만 작성 (deleted_user로 작성 금지)
      allow create: if request.auth != null && 
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.uid != "deleted_user" &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 200 &&
        request.resource.data.dateKey is string &&
        request.resource.data.timeSlot is string &&
        request.resource.data.bondGroupId is string &&
        request.resource.data.reports == 0;
      
      // 수정: 본인 게시물만 (익명화된 게시물 수정 금지)
      allow update: if request.auth != null && 
        resource.data.uid == request.auth.uid &&
        resource.data.uid != "deleted_user";
      
      // 삭제: 본인 게시물만
      allow delete: if request.auth != null && 
        resource.data.uid == request.auth.uid;

      // ── 신고 서브컬렉션 ──
      match /reports/{reportId} {
        // 읽기: 본인이 신고한 기록만 확인 가능
        allow read: if request.auth != null && 
          reportId == request.auth.uid;
        // 쓰기: 로그인한 유저만 (중복 신고는 서비스 로직에서 처리)
        allow create: if request.auth != null && 
          request.resource.data.reporterUid == request.auth.uid;
        allow update, delete: if false; // 신고는 생성만 가능
      }
    }

    // ══════════════════════════════════════════════════
    // 전광판 게시물 (Billboard Posts)
    // ══════════════════════════════════════════════════
    match /billboardPosts/{postId} {
      // 읽기: 개발용 - 모든 사용자 허용 (임시)
      allow read: if true;
      // 생성/삭제: 서버만 (Cloud Functions)
      allow create, delete: if false;
      // 업데이트: 반응 집계(reactions)만 클라이언트 허용
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

      // ── 유저별 반응 (글당 1개, 토글/변경) ──
      match /userReactions/{uid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null &&
          request.auth.uid == uid &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.emoji in ['👏', '❤️', '🔥', '😢'];
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ══════════════════════════════════════════════════
    // 파트너 그룹 내 주간 스탬프
    // ══════════════════════════════════════════════════
    match /partnerGroups/{groupId}/weeklyStamps/{stampId} {
      allow read: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/partnerGroups/$(groupId)).data.memberUids;
      allow write: if false; // 서버만
    }

    // ══════════════════════════════════════════════════
    // 🔐 API 키 (로그인한 모든 사용자 읽기 가능, 쓰기는 금지)
    // ══════════════════════════════════════════════════
    match /api_keys/{keyDoc} {
      allow read: if request.auth != null; // 로그인한 모든 사용자
      allow write: if false; // 콘솔 또는 서버에서만 수정
    }

    // ══════════════════════════════════════════════════
    // ⚙️ 설정 (로그인한 모든 사용자 읽기 가능)
    // ══════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if request.auth != null; // 로그인한 모든 사용자
      allow write: if false; // 콘솔에서만 수정
    }

    // ══════════════════════════════════════════════════
    // 📋 HIRA 업데이트 (급여/수가 변경)
    // ══════════════════════════════════════════════════
    match /content_hira_updates/{updateId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions만
      
      // ── 댓글 서브컬렉션 ──
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500;
        allow delete: if request.auth != null && 
          resource.data.uid == request.auth.uid;
        allow update: if false; // 댓글 수정 불가
      }
    }

    match /content_hira_digest/{dateKey} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions만
    }

    // ══════════════════════════════════════════════════
    // 💾 HIRA 저장 목록 (사용자별)
    // ══════════════════════════════════════════════════
    match /users/{uid}/saved_hira_updates/{updateId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow update: if false; // 생성/삭제만, 수정 불필요
    }

    // ══════════════════════════════════════════════════
    // 구인공고 (Jobs)
    // ══════════════════════════════════════════════════
    match /jobs/{jobId} {
      // 공고 읽기: 로그인한 모든 사용자 (published 상태)
      allow read: if request.auth != null;
      // 생성/수정/삭제: 서버(Cloud Functions)만 (createJobPosting Callable)
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 치과 사업자 인증 (Clinic Verifications)
    // ══════════════════════════════════════════════════
    match /clinicVerifications/{uid} {
      // 본인 기록만 읽기
      allow read: if request.auth != null && request.auth.uid == uid;
      // 최초 제출(pending): 본인만
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.status == 'pending';
      // 승인/거절 등 상태 변경: 서버만
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 🏥 치과(병원) (Clinics)
    // ══════════════════════════════════════════════════
    match /clinics/{clinicId} {
      // 읽기: 소유자/멤버 또는 지원자(공고 열람 시 병원 정보 참조)
      allow read: if request.auth != null;
      // 쓰기: 서버(Cloud Functions)만 – 인증 승인 시 자동 생성
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    // 📄 이력서 (Resumes)
    // ══════════════════════════════════════════════════
    match /resumes/{resumeId} {
      // 읽기: 본인만 (병원은 application 경유로 서버에서 조회)
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      // 생성: 본인 uid만
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      // 수정: 본인만
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      // 삭제: 본인만
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 🖼️ 이력서 OCR 가져오기 드래프트 (Resume Import Drafts)
    // ══════════════════════════════════════════════════
    match /resumeImportDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📝 이력서 편집 임시저장 (Resume Drafts)
    // ══════════════════════════════════════════════════
    match /resumeDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📨 지원서 (Applications)
    // ══════════════════════════════════════════════════
    match /applications/{applicationId} {
      // 읽기: 지원자 본인 또는 해당 병원 소유자
      allow read: if request.auth != null && (
        resource.data.applicantUid == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/clinics/$(resource.data.clinicId)).data.ownerUids
      );
      // 생성: 지원자 본인 uid로만
      allow create: if request.auth != null &&
        request.resource.data.applicantUid == request.auth.uid;
      // 수정: 서버만 (연락처 공개 등)
      allow update: if false;
      // 삭제: 지원자가 철회(withdraw) – 서버 Function 경유 권장
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // 📝 공고 임시저장 (Job Drafts)
    // ══════════════════════════════════════════════════
    match /jobDrafts/{draftId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 📊 공고 일별 통계 (Job Stats Daily)
    // ══════════════════════════════════════════════════
    match /jobStatsDaily/{docId} {
      // 읽기: 해당 공고의 병원 소유자만 (또는 로그인 유저 – MVP)
      allow read: if request.auth != null;
      // 쓰기: 서버만 (Cloud Functions에서 집계)
      allow write: if false;
    }

    // ══════════════════════════════════════════════════
    // 🔗 커리어 네트워크 (Career Network)
    // ══════════════════════════════════════════════════
    match /careerNetwork/{docId} {
      allow read: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow write: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════
    // 기타 컬렉션 (임시로 전체 허용 - 나중에 세분화 필요)
    // ══════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if true;
    }
  }
}